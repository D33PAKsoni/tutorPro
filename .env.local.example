# ============================================================
# TUITION PRO — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ---- Supabase ----
# Found at: Supabase Dashboard → Settings → API
#
# LOCAL DEVELOPMENT (supabase start):
#   VITE_SUPABASE_URL=http://localhost:54321
#   VITE_SUPABASE_ANON_KEY=<anon key printed by `supabase start`>
#
# IMPORTANT: Using the cloud URL (*.supabase.co) while running locally will cause
# "failed to communicate with edge function" errors because the edge functions
# (e.g. create-student-user) are only served by the local CLI, not the remote project.
# Always use http://localhost:54321 when developing locally.
#
# PRODUCTION (Supabase cloud):
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---- Google OAuth (for Drive backup) ----
# Found at: Google Cloud Console → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
VITE_GOOGLE_DRIVE_SCOPE=https://www.googleapis.com/auth/drive.file

# ---- VAPID (Web Push Notifications) ----
# Generate with: npx web-push generate-vapid-keys
# Only the PUBLIC key goes here — keep the PRIVATE key in Supabase Edge Function secrets
VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY_HERE

# ---- App Config ----
VITE_APP_NAME=Tuition Pro
# This is the fake domain suffix used for student logins
# e.g. username "john123" → email "john123@tuition.internal"
VITE_INTERNAL_EMAIL_DOMAIN=tuition.internal
